generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String          @id @default(cuid())
  email               String          @unique
  name                String
  phone               String?
  college             String?
  city                String?
  avatar              String?
  isVerified          Boolean         @default(false)
  isAdmin             Boolean         @default(false)
  adminRole           String?         // "super_admin" | "moderator" | "support_admin"
  passwordHash        String?         // bcrypt hashed password for admin accounts
  mustChangePassword  Boolean         @default(false) // force password change on first login
  isBanned            Boolean         @default(false)
  rating              Float           @default(0)
  totalSales          Int             @default(0)
  whatsapp            String?
  freeUploadUsed      Int             @default(0)
  paidUploadCredits   Int             @default(0)
  totalBooksUploaded  Int             @default(0)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  listings            Listing[]
  wishlistItems       Wishlist[]
  reports             Report[]        @relation("Reporter")
  adminSessions       AdminSession[]
  auditLogs           AuditLog[]      @relation("AuditActor")
  payments            Payment[]
  sessions            UserSession[]
}

model Listing {
  id             String     @id @default(cuid())
  title          String
  description    String
  originalPrice  Float
  sellingPrice   Float
  category       String
  subcategory    String?
  listingType    String     @default("sell")
  course         String?
  semester       String?
  standard       String?
  board          String?
  college        String?
  city           String
  condition      String
  images         String     @default("[]")
  whatsappNumber String
  isFeatured     Boolean    @default(false)
  isUrgent       Boolean    @default(false)
  isVerified     Boolean    @default(false)
  isSold         Boolean    @default(false)
  isDigital      Boolean    @default(false)
  fileUrl        String?
  views          Int        @default(0)
  saves          Int        @default(0)
  sellerId       String
  seller         User       @relation(fields: [sellerId], references: [id])
  wishlistBy     Wishlist[]
  reports        Report[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  user      User     @relation(fields: [userId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
}

model Report {
  id         String   @id @default(cuid())
  listingId  String
  reporterId String
  reason     String
  isResolved Boolean  @default(false)
  listing    Listing  @relation(fields: [listingId], references: [id])
  reporter   User     @relation("Reporter", fields: [reporterId], references: [id])
  createdAt  DateTime @default(now())
}

model AdminSession {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  isRevoked    Boolean  @default(false)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation("AuditActor", fields: [actorId], references: [id])
  action     String   // "ban_user" | "delete_listing" | "verify_seller" | etc.
  targetType String   // "user" | "listing" | "report"
  targetId   String
  details    String?  // JSON string with extra info
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

model Payment {
  id              String   @id @default(cuid())
  userId          String
  amount          Float    @default(10)
  paymentMethod   String   @default("upi_qr") // "upi_qr" | "razorpay"
  utrNumber       String?  // UTR/reference number from user
  screenshotUrl   String?  // uploaded screenshot URL
  upiId           String?  // UPI ID used for payment
  status          String   @default("pending") // "pending" | "verified" | "rejected" | "expired"
  uploadCredit    Int      @default(1) // credits granted after verification
  expiresAt       DateTime // 5 minute expiry for pending payments
  verifiedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([utrNumber])
  @@index([expiresAt])
}

model RateLimitEntry {
  id        String   @id @default(cuid())
  key       String   @unique // IP or userId + route
  count     Int      @default(1)
  resetAt   DateTime
  createdAt DateTime @default(now())

  @@index([key])
  @@index([resetAt])
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  isRevoked    Boolean  @default(false)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetOTP {
  id         String   @id @default(cuid())
  email      String                                    // admin email
  phone      String                                    // phone number OTP sent to
  otpCode    String                                    // 6-digit OTP
  isVerified Boolean  @default(false)                  // whether OTP was successfully verified
  expiresAt  DateTime                                  // 5-minute expiry
  createdAt  DateTime  @default(now())
  usedAt     DateTime?                                 // when OTP was used

  @@index([email])
  @@index([otpCode])
  @@index([expiresAt])
}
