# Neon Database Connection
# Get these from: https://console.neon.tech → Your Project → Dashboard → Connection Details

# Pooled connection (for Prisma client - serverless optimized)
DATABASE_URL="postgresql://neondb:password@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Direct connection (for Prisma migrations)
DIRECT_URL="postgresql://neondb:password@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
